{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clawdometer",
  "version": "0.5.5",
  "identifier": "io.github.clawdometer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self'"
    },
    "windows": [
      {
        "label": "hud",
        "title": "Clawdometer",
        "width": 200,
        "height": 112,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "shadow": false,
        "transparent": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzODg2OEFCQkJCMUY3RUUKUldUdTk3RzdxMmlJVXlXWDM3TURxcElUMWR4S3RtVGVTbHZmWEx3bnc3dDBQMmZHb1dLaWZFWU8K",
      "endpoints": [
        "https://github.com/cthpAiden/Clawdometer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Phuc Chau",
    "copyright": "Copyright (c) 2026 Phuc Chau",
    "licenseFile": "../../LICENSE",
    "icon": ["icons/icon.ico"]
  }
}
