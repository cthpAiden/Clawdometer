{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clawdometer",
  "version": "0.2.2",
  "identifier": "io.github.clawdometer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self'"
    },
    "windows": [
      {
        "label": "hud",
        "title": "Clawdometer",
        "width": 200,
        "height": 112,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "shadow": false,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Phuc Chau",
    "copyright": "Copyright (c) 2026 Phuc Chau",
    "licenseFile": "../../LICENSE",
    "icon": ["icons/icon.ico"]
  }
}
